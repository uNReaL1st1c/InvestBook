		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СпотовыеСделки.Криптовалюта КАК Криптовалюта,
	СУММА(СпотовыеСделки.Прибыль) КАК Прибыль
ПОМЕСТИТЬ ВТ_ПрибыльПоКриптовалюте
ИЗ
	РегистрНакопления.СпотовыеСделки КАК СпотовыеСделки

СГРУППИРОВАТЬ ПО
	СпотовыеСделки.Криптовалюта
	
ИНДЕКСИРОВАТЬ ПО
	Криптовалюта		
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СпотовыеСделкиОстатки.Криптовалюта КАК Криптовалюта,
	СпотовыеСделкиОстатки.КоличествоОстаток КАК КоличествоОстаток,
	СпотовыеСделкиОстатки.СуммаОстаток КАК СуммаОстаток
ПОМЕСТИТЬ ВТ_ТекущиеАктивы
ИЗ
	РегистрНакопления.СпотовыеСделки.Остатки({(&amp;ДатаСреза)}, ) КАК СпотовыеСделкиОстатки
ИНДЕКСИРОВАТЬ ПО
	Криптовалюта	
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныКриптовалютныхАктивовСрезПоследних.Криптовалюта КАК Криптовалюта,
	ЦеныКриптовалютныхАктивовСрезПоследних.Цена КАК Цена
ПОМЕСТИТЬ ВТ_ТекущиеЦеныАктивов
ИЗ
	РегистрСведений.ЦеныКриптовалютныхАктивов.СрезПоследних(
			{(&amp;ДатаСреза)},
			Криптовалюта В
				(ВЫБРАТЬ
					ВТ_ТекущиеАктивы.Криптовалюта
				ИЗ
					ВТ_ТекущиеАктивы)) КАК ЦеныКриптовалютныхАктивовСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ТекущиеАктивы.Криптовалюта КАК Криптовалюта,
	ВТ_ТекущиеАктивы.КоличествоОстаток КАК КоличествоОстаток,
	ЕСТЬNULL(ВТ_ТекущиеЦеныАктивов.Цена, 0) КАК ТекущаяЦена,
	ВТ_ТекущиеАктивы.СуммаОстаток КАК СуммаПокупкиАктивов,
	ВТ_ТекущиеАктивы.КоличествоОстаток * ЕСТЬNULL(ВТ_ТекущиеЦеныАктивов.Цена, 0) КАК ТекущаяСтоимостьАктивов,
	ВТ_ТекущиеАктивы.КоличествоОстаток * ЕСТЬNULL(ВТ_ТекущиеЦеныАктивов.Цена, 0) - ВТ_ТекущиеАктивы.СуммаОстаток КАК РазницаПриПродаже,
	0 КАК Прибыль,
	0 КАК СуммаВРубляхОборот,
	0 КАК СуммаВUSDTОборот,
	0 КАК КомиссияСетиОборот
ИЗ
	ВТ_ТекущиеАктивы КАК ВТ_ТекущиеАктивы
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТекущиеЦеныАктивов КАК ВТ_ТекущиеЦеныАктивов
		ПО ВТ_ТекущиеАктивы.Криптовалюта = ВТ_ТекущиеЦеныАктивов.Криптовалюта

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_ПрибыльПоКриптовалюте.Криптовалюта,
	0,
	0,
	0,
	0,
	0,
	ВТ_ПрибыльПоКриптовалюте.Прибыль,
	0,
	0,
	0
ИЗ
	ВТ_ПрибыльПоКриптовалюте КАК ВТ_ПрибыльПоКриптовалюте
</query>
